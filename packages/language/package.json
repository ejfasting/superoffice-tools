{
  "name": "crmscript-language",
  "version": "0.0.1",
  "description": "The language specific package",
  "files": [
    "out",
    "src"
  ],
  "type": "module",
  "main": "./out/index.js",
  "module": "./out/index.js",
  "typesVersions": {
    "*": {
      ".": [
        "out/index"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./out/index.js"
    }
  },
  "scripts": {
    "clean": "shx rm -fr *.tsbuildinfo out",
    "build": "tsgo -b tsconfig.json",
    "build:clean": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch"
  },
  "dependencies": {
    "langium": "~4.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.18",
    "langium-cli": "~4.2.0",
    "vitest": "catalog:",
    "vscode-languageserver": "catalog:"
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.3"
  }
}
