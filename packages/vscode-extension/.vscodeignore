# Exclude source maps (not needed at runtime)
dist/**/*.js.map

# Source files (compiled to out/)
src/
tsconfig.json

# Dev/config files
.gitignore
.gitattributes
*.vsix

# Test workspace and setup
../../test-workspace/
../../setup/

# Node modules (all deps are bundled into out/extension.js by esbuild)
node_modules/
**/*.ts
**/tsconfig.json

esbuild.js
