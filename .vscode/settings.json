{
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "js/ts.experimental.useTsgo": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.typeAware": true,
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "editor.formatOnSave": true,
  "cSpell.words": [
    "isnan",
    "nonconstructor",
    "oxfmt",
    "oxfmtrc",
    "oxlint",
    "oxlintrc",
    "tsgolint",
    "uninvoked"
  ]
}
