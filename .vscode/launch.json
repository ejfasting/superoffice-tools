// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "vscode-extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension",
        "--disable-extensions",
        "--folder-uri=${workspaceRoot}/test-workspace"
      ],
      "outFiles": ["${workspaceFolder}/packages/vscode-extension/dist/**/*.js"],
      "preLaunchTask": "watch"
    },
    {
      "name": "Run langium",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/langium-crmscript/packages/extension",
        "--disable-extensions",
        "--folder-uri=${workspaceRoot}/test-workspace"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/packages/langium-crmscript/packages/language/out/**/*.js",
        "${workspaceFolder}/packages/langium-crmscript/packages/extension/out/**/*.js"
      ]
    }
  ]
}
